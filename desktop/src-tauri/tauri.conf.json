{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Noteriv",
  "version": "2.0.0",
  "identifier": "com.noteriv.app",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "npm run build:next",
    "devUrl": "http://localhost:3456",
    "frontendDist": "../out"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Noteriv",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": false,
        "transparent": false,
        "backgroundColor": "#1e1e2e",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": -100, "y": -100 }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Modern markdown editor with plugins, themes, and sync.",
    "longDescription": "Noteriv is a modern markdown editor with a plugin API, themes, and Git/WebDAV sync."
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/thejacedev/Noteriv/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDEwQTc0OUYzQTFDOURBNEYKUldSUDJzbWg4MG1uRUhUbit3ZUgyVVUvVnYwK3BUWUQ0T3g3eXV6d2szYVllNHgvYkJncmV3eDEK",
      "dialog": false
    }
  }
}
