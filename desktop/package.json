{
  "name": "noteriv",
  "version": "2.0.1",
  "description": "Noteriv — modern markdown editor with plugins, themes, sync",
  "author": {
    "name": "Jace Sleeman",
    "email": "jace@noteriv.com"
  },
  "homepage": "https://noteriv.com",
  "private": true,
  "scripts": {
    "dev:next": "next dev --port 3456 --webpack",
    "dev:tauri": "wait-on http-get://localhost:3456 && WEBKIT_DISABLE_DMABUF_RENDERER=1 WEBKIT_DISABLE_COMPOSITING_MODE=1 tauri dev",
    "dev": "concurrently --kill-others \"npm run dev:next\" \"npm run dev:tauri\"",
    "build:next": "next build",
    "build": "npm run build:next && tauri build",
    "tauri": "tauri",
    "lint": "eslint"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.2",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.16",
    "@lezer/highlight": "^1.2.3",
    "@replit/codemirror-vim": "^6.3.0",
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-dialog": "^2.2.0",
    "@tauri-apps/plugin-shell": "^2.2.0",
    "@tauri-apps/plugin-updater": "^2.3.0",
    "concurrently": "^9.2.1",
    "katex": "^0.16.38",
    "mermaid": "^11.13.0",
    "next": "16.1.6",
    "pdfjs-dist": "^5.5.207",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "wait-on": "^9.0.4",
    "y-webrtc": "^10.3.0",
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tauri-apps/cli": "^2.1.0",
    "@types/katex": "^0.16.8",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
